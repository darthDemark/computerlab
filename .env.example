# ============================================================
# CS LAB — Environment Variables
# ============================================================
# Provide EITHER an Anthropic key OR an OpenAI key. If both are
# set, Anthropic is preferred. Keys are read ONLY on the server
# (in /api/ai/*) and are NEVER exposed to the browser.
#
# With no key set, the AI routes return a structured offline
# template so the prototype stays fully clickable.

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
# Optional model override (default: claude-3-5-sonnet-latest)
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- OpenAI ---
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
